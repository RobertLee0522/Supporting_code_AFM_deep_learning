# Keep the repo focused on source code and a few small parameter files.
*

# Always keep the ignore file itself.
!.gitignore

# Python source and packages.
!**/
!**/*.py

# Small runtime / setup inputs that are useful to version.
!requirements.txt
!install_tf_gpu.bat

# Optional text-based references that are still lightweight.
!CLAUDE.md
!README.md
!DETECT_README.md
!GPU_SETUP_GUIDE.md
!OPTIMIZATION_SUMMARY.md

# 電子研究紀錄簿（lab_notebook/）：輕量文字檔，記錄每次調查/修正的
# 研究過程與結論，版控以利追蹤決策脈絡。
!lab_notebook/
!lab_notebook/*.md

# runs/ 目錄：完全不追蹤（權重 / 圖片 / log 均不上傳）
runs/

# Temporary / generated content.
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/
.claude/
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
img/
結果/
分析/
afm/
afm_broken_py37_backup/

# Large data / notebooks / reports.
*.npy
*.mat
*.pdf
*.ipynb
*.zip
*.tar.gz
*.7z
*.keras
*.h5
*.save
*.weights

# Logs and scratch files.
*.log
*.tmp
